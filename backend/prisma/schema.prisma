generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id         Int       @id @default(autoincrement())
  email      String    @unique
  password   String
  name       String
  isApproved Boolean   @default(true)
  isAdmin    Boolean   @default(false)
  zoomLevel              Int       @default(50)
  notificationsReadAt    DateTime?
  lastLoginAt            DateTime?
  loginCount             Int       @default(0)
  createdAt              DateTime  @default(now())
  defaultBubbleId      Int?
  contents   Content[]
  reviews    Review[]
  votes      Vote[]
  passwordResetTokens  PasswordResetToken[]
  bubbleMemberships    BubbleMembership[]
  bubblesCreated       Bubble[]           @relation("BubbleCreator")
  bubbleInvitesSent    BubbleInvitation[] @relation("BubbleInviter")
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  tokenHash String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Content {
  id          Int       @id @default(autoincrement())
  title       String
  author      String
  coverImage  String
  summary     String
  whyRead     String
  rating      Float
  sponsor     String
  support     String?
  genre       String?
  url         String?
  publishDate DateTime?
  userId      Int
  user        User      @relation(fields: [userId], references: [id])
  bubbleId    Int?
  bubble      Bubble?   @relation(fields: [bubbleId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  reviews     Review[]
  votes       Vote[]
}

model Bubble {
  id          Int      @id @default(autoincrement())
  name        String
  createdAt   DateTime @default(now())
  createdById Int
  createdBy   User     @relation("BubbleCreator", fields: [createdById], references: [id])
  members     BubbleMembership[]
  contents    Content[]
  invitations BubbleInvitation[]
}

model BubbleMembership {
  id        Int      @id @default(autoincrement())
  userId    Int
  bubbleId  Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bubble    Bubble   @relation(fields: [bubbleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@unique([userId, bubbleId])
}

model BubbleInvitation {
  id          Int      @id @default(autoincrement())
  token       String   @unique
  email       String
  bubbleId    Int
  invitedById Int
  bubble      Bubble   @relation(fields: [bubbleId], references: [id], onDelete: Cascade)
  invitedBy   User     @relation("BubbleInviter", fields: [invitedById], references: [id])
  used        Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Tag {
  id        Int      @id @default(autoincrement())
  type      String   // "support" ou "genre"
  value     String
  createdAt DateTime @default(now())
  @@unique([type, value])
}

model Review {
  id        Int      @id @default(autoincrement())
  rating    Float
  comment   String
  userId    Int
  contentId Int
  user      User     @relation(fields: [userId], references: [id])
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, contentId])
}

model Vote {
  id        Int      @id @default(autoincrement())
  type      String   // "UP" | "DOWN"
  userId    Int
  contentId Int
  user      User     @relation(fields: [userId], references: [id])
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, contentId])
}
